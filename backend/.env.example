# Copy to .env on the server — never commit real keys
API_FOOTBALL_KEY=

# Optional: blend predictions with bookmaker odds (the-odds-api.com)
THE_ODDS_API_KEY=

# Optional: persist Elo + live matches across Render redeploys (GitHub Gist)
# Create token: GitHub → Settings → Developer settings → Fine-grained token (Gist: read/write)
GITHUB_GIST_TOKEN=
GITHUB_GIST_ID=

