# Copy to .env on the server — never commit real keys
API_FOOTBALL_KEY=

# Phase 4R.3 — API-Football historical national-team recent-form (fusion provider)
API_FOOTBALL_ENABLED=true
API_FOOTBALL_API_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_SEASONS=2022,2023,2024
API_FOOTBALL_TIMEOUT_SECONDS=15
API_FOOTBALL_SLEEP_SECONDS=0.5

# Phase 4X — football-data.org World Cup fixtures (primary external provider when set)
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_ENABLED=true

# Phase 4O — home advantage on composite power scale (typical team power ~700–900)
HOME_ADVANTAGE_POWER_POINTS=35

# Optional: blend predictions with bookmaker odds (the-odds-api.com)
THE_ODDS_API_KEY=

# Phase 4H — odds diagnostics-only by default (set true to restore 70/30 1X2 blend)
ODDS_AFFECT_PREDICTION=false

# Phase 4H — calibration readiness (default off; blocked until coherence gate passes)
PROBABILITY_CALIBRATION_ENABLED=false
PROBABILITY_CALIBRATION_METHOD=temperature
PROBABILITY_CALIBRATION_TEMPERATURE=1.35

# Optional: persist Elo + live matches across Render redeploys (GitHub Gist)
# Create token: GitHub → Settings → Developer settings → Fine-grained token (Gist: read/write)
GITHUB_GIST_TOKEN=
GITHUB_GIST_ID=

# Optional: run `python run_fetch_quota_safe.py` (qualifiers only, ~80 API calls max)
# Or POST /api/admin/refresh-history when API_FOOTBALL_KEY is set on the server
# Match context (rest/travel) uses API_FOOTBALL_KEY; weather uses Open-Meteo (no key)

# Phase 4R.2 — football-data.org recent-form cache (diagnostics only; no scoreline effect by default)
RECENT_FORM_API_ENABLED=true
RECENT_FORM_CACHE_TTL_HOURS=24
RECENT_FORM_REFRESH_TIMEOUT_SECONDS=3
RECENT_FORM_AFFECTS_SCORELINE=false
